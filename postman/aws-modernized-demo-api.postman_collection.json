                  "};",
                  "pm.test('Token exchange is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "setVar('access_token', body.access_token || '');",
                  "setVar('id_token', body.id_token || '');",
                  "setVar('refresh_token', body.refresh_token || '');",
                  "setVar('access_token_type', body.token_type || '');",
                  "setVar('access_token_expires_in', body.expires_in !== undefined ? String(body.expires_in) : '');"
                ]
              }
            }
          ],

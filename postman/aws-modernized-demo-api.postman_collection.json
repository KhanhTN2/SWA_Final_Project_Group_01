{
  "info": {
    "_postman_id": "ed9f4483-3cb7-480f-a62e-3009fd83b4fa",
    "name": "AWS Modernized Demo API",
    "description": "API requests for Demo 1 happy path, Demo 2 failover, and Demo 3 circuit-breaker flows. Set {{access_token}} in the imported environment before running folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Demo 1 - Happy Path",
      "item": [
        {
          "name": "GET Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Demo 1 product check is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.numberOnStock !== undefined) {",
                  "  pm.environment.set('demo1_last_stock', String(body.numberOnStock));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "{{demo1_correlation_id}}"
              }
            ],
            "url": "{{api_gateway_endpoint}}/product/{{product_number}}",
            "description": "Matches Demo 1 product check in docs/demo-scenario.md."
          }
        },
        {
          "name": "POST Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Demo 1 order create is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.environment.set('demo1_order_id', body.orderId || '');",
                  "pm.environment.set('demo1_order_status', body.status || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{demo1_correlation_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productNumber\": \"{{product_number}}\",\n  \"quantity\": {{quantity}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{api_gateway_endpoint}}/orders"
          }
        },
        {
          "name": "GET Order Lookup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Demo 1 order lookup is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "{{demo1_correlation_id}}"
              }
            ],
            "url": "{{api_gateway_endpoint}}/orders/{{demo1_order_id}}"
          }
        }
      ]
    },

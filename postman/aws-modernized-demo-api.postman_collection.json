    {
      "name": "Auth - Get Token",
      "item": [
        {
          "name": "Hosted UI Login Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setVar = (key, value) => {",
                  "  pm.collectionVariables.set(key, value);",
                  "  try {",
                  "    if (pm.environment && pm.environment.name) {",
                  "      pm.environment.set(key, value);",
                  "    }",
                  "  } catch (error) {}",
                  "};",
                  "const unsetVar = (key) => {",
                  "  pm.collectionVariables.unset(key);",
                  "  try {",
                  "    if (pm.environment && pm.environment.name) {",
                  "      pm.environment.unset(key);",
                  "    }",
                  "  } catch (error) {}",
                  "};",
                  "const getVar = (key) => {",
                  "  const value = pm.variables.get(key);",
                  "  if (value !== undefined && value !== null && value !== '') {",
                  "    return value;",
                  "  }",
                  "  return pm.collectionVariables.get(key);",
                  "};",
                  "const status = pm.response.code;",
                  "if ([302, 303].includes(status)) {",
                  "  const location = pm.response.headers.get('Location') || '';",
                  "  const codeMatch = location.match(/[?&]code=([^&]+)/);",
                  "  pm.expect(codeMatch, 'authorization code').to.not.be.null;",
                  "  setVar('cognito_authorization_code', decodeURIComponent(codeMatch[1]));",
                  "  setVar('cognito_redirect_location', location);",
                  "} else {",
                  "  pm.test('Hosted UI login page is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "  });",
                  "  const body = pm.response.text();",
                  "  const formActionMatch = body.match(/<form[^>]+action=\\\"([^\\\"]+)\\\"/);",
                  "  const csrfMatch = body.match(/name=\\\"_csrf\\\" value=\\\"([^\\\"]+)\\\"/);",
                  "  pm.expect(formActionMatch, 'login form action').to.not.be.null;",
                  "  pm.expect(csrfMatch, 'csrf token').to.not.be.null;",
                  "  const relativeAction = formActionMatch[1].replace(/&amp;/g, '&');",
                  "  const baseUrl = getVar('cognito_hosted_ui_base_url');",
                  "  const absoluteAction = relativeAction.startsWith('http') ? relativeAction : `${baseUrl}${relativeAction}`;",
                  "  setVar('cognito_login_form_action', absoluteAction);",
                  "  setVar('cognito_csrf', csrfMatch[1]);",
                  "}",
                  "unsetVar('access_token');",
                  "unsetVar('id_token');",
                  "unsetVar('refresh_token');"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{cognito_hosted_ui_base_url}}/login?response_type=code&client_id={{cognito_app_client_id}}&redirect_uri={{cognito_redirect_uri}}&scope={{cognito_scope}}",
            "description": "Loads the Cognito Hosted UI login page and stores the form action plus CSRF token. If a valid Cognito session cookie already exists, this can return an authorization code redirect directly."
          }
        },
        {
          "name": "Hosted UI Login Form",

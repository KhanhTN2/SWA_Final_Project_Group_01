                  "    }",
                  "  } catch (error) {}",
                  "};",
                  "pm.test('Hosted UI login returns redirect', function () {",
                  "  pm.expect([302, 303]).to.include(pm.response.code);",
                  "});",
                  "const location = pm.response.headers.get('Location') || '';",
                  "const codeMatch = location.match(/[?&]code=([^&]+)/);",
                  "pm.expect(codeMatch, 'authorization code').to.not.be.null;",
                  "setVar('cognito_authorization_code', decodeURIComponent(codeMatch[1]));",
                  "setVar('cognito_redirect_location', location);"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {

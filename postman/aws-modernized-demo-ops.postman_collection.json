              },
              {
                "key": "X-Amz-Target",
                "value": "AmazonEC2ContainerServiceV20141113.ListTasks"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cluster\": \"{{ecs_cluster_name}}\",\n  \"serviceName\": \"{{inventory_service_name}}\",\n  \"desiredStatus\": \"RUNNING\"\n}",
              "options": {

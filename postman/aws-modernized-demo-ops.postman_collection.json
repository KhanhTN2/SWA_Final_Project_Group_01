  "item": [
    {
      "name": "Setup And Visibility",
      "item": [
        {
          "name": "Describe ECS Services",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Describe services is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "awsv4",
              "awsv4": [
                {
                  "key": "accessKey",
                  "value": "{{aws_access_key_id}}",
                  "type": "string"
                },
                {
                  "key": "secretKey",
                  "value": "{{aws_secret_access_key}}",
                  "type": "string"
                },
                {
                  "key": "sessionToken",
                  "value": "{{aws_session_token}}",
                  "type": "string"
                },
                {
                  "key": "region",
                  "value": "{{aws_region}}",
                  "type": "string"
                },
                {
                  "key": "service",
                  "value": "ecs",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-amz-json-1.1"
              },
              {
                "key": "X-Amz-Target",
                "value": "AmazonEC2ContainerServiceV20141113.DescribeServices"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cluster\": \"{{ecs_cluster_name}}\",\n  \"services\": [\n    \"{{order_service_name}}\",\n    \"{{inventory_service_name}}\",\n    \"{{notification_service_name}}\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "https://ecs.{{aws_region}}.amazonaws.com/"
          }
        },

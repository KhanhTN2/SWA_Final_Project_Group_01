        {
          "name": "List Inventory Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.taskArns && body.taskArns.length > 0) {",
                  "  pm.environment.set('inventory_task_to_stop', body.taskArns[0]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "awsv4",
